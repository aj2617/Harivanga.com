rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name, description, image, pricePerKg, stock, variety, origin, tasteProfile, isAvailable, variants[]
    //
    // Collection: orders
    // Fields: customerName, customerPhone, deliveryAddress, deliveryArea, deliveryDate, paymentMethod, items[], subtotal, deliveryCharge, total, status, createdAt, userId
    //
    // Collection: users
    // Fields: name, phone, email, role, savedAddresses[]
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ashadujjaman2617@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && request.auth.uid == orderData.userId;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.pricePerKg is number && data.pricePerKg >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.variety is string &&
             data.isAvailable is bool;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.customerPhone is string && data.customerPhone.size() >= 10 &&
             data.deliveryAddress is string && data.deliveryAddress.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Confirmed', 'Out for Delivery', 'Delivered'] &&
             data.createdAt is string; // ISO string
    }

    function isValidUser(data) {
      return data.role in ['admin', 'customer'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner(resource.data);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isOrderOwner(resource.data) && request.resource.data.status == resource.data.status); // Customers can't change status
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'customer';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}

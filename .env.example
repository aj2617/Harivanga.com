# Supabase project URL and anon key for client-side auth and data access.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional: set when hosting under a subfolder (e.g. https://example.com/shop/ -> "/shop/").
# Leave unset for root-domain hosting.
# VITE_BASE_PATH="/shop/"

# Optional for local/dev direct Gemini access from the browser.
# Note: this exposes the key to the client, so prefer the Supabase Edge Function for production.
# VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# VITE_GEMINI_MODEL="gemini-2.5-flash"

# Supabase Edge Function secret to set on the server:
# supabase secrets set GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# Optional server-side model override:
# supabase secrets set GEMINI_MODEL="gemini-2.5-flash"

# Optional: Order notifications (set as Supabase secrets, not in VITE_ env vars)
# Email via Resend:
# supabase secrets set RESEND_API_KEY="YOUR_RESEND_API_KEY"
# supabase secrets set NOTIFY_ADMIN_EMAIL="you@example.com"
# supabase secrets set NOTIFY_EMAIL_FROM="Orders <orders@yourdomain.com>"
# WhatsApp via Twilio:
# supabase secrets set TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# supabase secrets set TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# supabase secrets set TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# supabase secrets set NOTIFY_WHATSAPP_TO="whatsapp:+8801XXXXXXXXX"
# Service role key for the Edge Function to read orders + log notifications:
# Supabase often provides SUPABASE_SERVICE_ROLE_KEY automatically to Edge Functions.
# If it is not available in your project, set:
# supabase secrets set SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
